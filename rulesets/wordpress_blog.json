{
  "meta": {
    "name": "WordPress Blog",
    "description": "WordPress-specific blog extraction selectors",
    "author": "Page Capture",
    "contributors": ["stevenpelletier90 (blog-tool patterns)"],
    "source": "https://github.com/stevenpelletier90/blog-tool",
    "version": "1.0.0"
  },
  "rules": [
    {"name": "h1", "description": "First H1 heading", "category": "content", "type": "text", "selector": ".entry-title, .post-title, h1"},
    {"name": "published_date", "description": "Publication date", "category": "meta", "type": "text", "selector": "time[datetime], .entry-date, .post-date, .date, .published, time.published, [itemprop='datePublished'], meta[property='article:published_time']"},
    {"name": "author", "description": "Post author", "category": "meta", "type": "text", "selector": ".entry-author, .post-author, .author, [rel='author'], .byline, meta[name='author'], [itemprop='author']"},
    {"name": "categories", "description": "Post categories", "category": "taxonomy", "type": "text", "selector": "a[rel='category tag'], .category, .categories a, .post-categories a, .post-categories li, .entry-categories a, meta[name='article:section']", "multiple": true},
    {"name": "tags", "description": "Post tags", "category": "taxonomy", "type": "text", "selector": "[rel='tag'], .tag a, .tags a, .post-tags a, .post-tags li, .entry-tags a", "multiple": true},
    {"name": "featured_image", "description": "Featured image URL", "category": "images", "type": "attribute", "selector": ".wp-post-image, .post-thumbnail img, .featured-image img, article img:first-of-type, [itemprop='image']", "attribute": "src"},
    {"name": "content_html", "description": "Full post content HTML", "category": "content", "type": "html", "selector": "div.blogContent, div.elementor-widget-theme-post-content, div[data-elementor-type='wp-post'], div[data-elementor-type='wp-page'], article .entry-content, .post-content, .entry-content, article, [itemprop='articleBody']"},
    {"name": "content_text", "description": "Post content plain text", "category": "content", "type": "text", "selector": "div.blogContent, div.elementor-widget-theme-post-content, div[data-elementor-type='wp-post'], div[data-elementor-type='wp-page'], article .entry-content, .post-content, .entry-content, article, [itemprop='articleBody']"},
    {"name": "content_images", "description": "All image URLs in content", "category": "images", "type": "attribute", "selector": "div.blogContent img, div[data-elementor-type] img, .entry-content img, .post-content img, article img", "attribute": "src", "multiple": true},
    {"name": "content_image_alts", "description": "Alt text for all images", "category": "images", "type": "attribute", "selector": "div.blogContent img, div[data-elementor-type] img, .entry-content img, .post-content img, article img", "attribute": "alt", "multiple": true},
    {"name": "meta_description", "description": "Meta description content", "category": "meta", "type": "meta", "selector": "meta[name='description']", "attribute": "name"},
    {"name": "og_title", "description": "Open Graph title", "category": "open_graph", "type": "meta", "selector": "meta[property='og:title']", "attribute": "property"},
    {"name": "og_image", "description": "Open Graph image URL", "category": "open_graph", "type": "meta", "selector": "meta[property='og:image']", "attribute": "property"},
    {"name": "og_description", "description": "Open Graph description", "category": "open_graph", "type": "meta", "selector": "meta[property='og:description']", "attribute": "property"}
  ]
}